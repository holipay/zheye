# Database Configuration
DATABASE_URL=postgresql+asyncpg://zheye:PASSWORD@localhost:5432/zheye

# DeepSeek API (for AI analysis)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com

# LLM Classification (混合分类: 关键词 + LLM)
# 设置为 false 可关闭 LLM 分类，仅使用关键词匹配
USE_LLM_CLASSIFIER=true

# NER (命名实体识别)
# 使用 spaCy 进行实体识别，支持中英文
# 设置为 false 可关闭 NER，仅使用正则匹配
USE_NER=true

# TF-IDF 语义去重
# 使用 TF-IDF + 余弦相似度进行语义去重
# 设置为 false 可关闭 TF-IDF，仅使用传统 n-gram 去重
USE_TFIDF_DEDUP=true

# Translation APIs (optional, can use free tier)
MYMEMORY_EMAIL=your_email@example.com

# ============================================================
# Market Data APIs (optional, for real-time data)
# ============================================================

# ExchangeRate-API (汇率数据，免费计划 1500 请求/月)
# 注册: https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=

# Alpha Vantage (股票、外汇、商品、加密货币)
# 注册: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Trading Economics (经济日历、宏观数据)
# 注册: https://tradingeconomics.com/api
TRADING_ECONOMICS_KEY=

# ============================================================
# Application Settings
# ============================================================
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# Admin Authentication (required for admin panel)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# CSRF Secret Key (用于 CSRF 保护，留空则使用 ADMIN_PASSWORD)
CSRF_SECRET_KEY=

# Cache Settings
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=100

# ============================================================
# AI Settings
# ============================================================
AI_MAX_RETRIES=3
AI_TIMEOUT_SECONDS=30
AI_DAILY_BUDGET=10.0
AI_CONFIDENCE_THRESHOLD=0.7
AI_CONFIDENCE_ENABLED=true
AI_RETRY_MAX_RETRIES=3
AI_RETRY_BASE_DELAY=60
AI_VERSION_KEEP_COUNT=5

# ============================================================
# Scraping Settings
# ============================================================
FETCH_TIMEOUT=20
MAX_RETRIES=2
DEDUP_THRESHOLD=0.75
RETENTION_DAYS=0

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_API=30/minute
RATE_LIMIT_ADMIN=120/minute

# ============================================================
# Deep Analysis (深度分析模块)
# ============================================================
ENABLE_DEEP_ANALYST=false
DEEP_ANALYSIS_MAX_EVENTS=10
DEEP_ANALYSIS_COOLDOWN_HOURS=24

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=/opt/zheye/logs/app.log
