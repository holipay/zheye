# Database Configuration
DATABASE_URL=postgresql+asyncpg://zheye:PASSWORD@localhost:5432/zheye

# DeepSeek API (for AI analysis)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com

# Translation APIs (optional, can use free tier)
MYMEMORY_EMAIL=your_email@example.com

# Application Settings
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# Cache Settings
CACHE_TTL_SECONDS=300

# Scraping Settings
FETCH_TIMEOUT=20
MAX_RETRIES=2
DEDUP_THRESHOLD=0.75
RETENTION_DAYS=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=/opt/zheye/logs/app.log
